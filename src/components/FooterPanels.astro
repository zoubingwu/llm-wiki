---
interface LinkItem {
  title: string;
  url: string;
}

interface Props {
  related: LinkItem[];
  backlinks: LinkItem[];
  sources: LinkItem[];
}

const { related, backlinks, sources } = Astro.props;
const sections = [
  { title: "See also", items: related },
  { title: "Backlinks", items: backlinks },
  { title: "References", items: sources }
].filter((section) => section.items.length > 0);
---

{
  sections.length > 0 && (
    <div class="content-tail" data-pagefind-ignore>
      {sections.map((section) => (
        <section class="content-tail__section">
          <h2>{section.title}</h2>
          <ul>
            {section.items.map((item) => (
              <li>
                <a href={item.url}>{item.title}</a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )
}
