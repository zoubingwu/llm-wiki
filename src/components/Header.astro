---
import SearchBox from "./SearchBox.astro";

const githubUrl = "https://github.com/zoubingwu/llm-wiki";
---

<header class="site-header">
  <div class="site-header__leading" aria-hidden="true">
    <span class="site-header__menu-icon">☰</span>
  </div>
  <div class="site-header__brand">
    <a href="/" class="site-header__wordmark">LLM Wiki</a>
    <span class="site-header__tagline">A personal encyclopedia</span>
  </div>
  <div class="site-header__search">
    <SearchBox />
  </div>
  <nav class="site-header__actions" aria-label="Primary">
    <a href={githubUrl} rel="noreferrer" target="_blank">GitHub</a>
  </nav>
</header>
