---
import { getCollection } from "astro:content";
import { statSync } from "node:fs";
import { basename, join } from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import { pageUrl } from "../lib/wiki/paths";
import { parseRecentLogEntries, pickFeaturedConcepts, sortLatestArticles } from "../lib/wiki/home";

function fileTitle(entry: { id: string; filePath?: string }) {
  return entry.filePath ? basename(entry.filePath, ".md") : entry.id;
}

const wikiEntries = await getCollection("wiki");
const articleEntries = await getCollection("articles");

const indexEntry = wikiEntries.find((entry) => entry.id === "index");
const logEntry = wikiEntries.find((entry) => entry.id === "log");

const featured = pickFeaturedConcepts(indexEntry?.body ?? "").map((title) => ({
  title,
  url: pageUrl("wiki", title),
}));

const recentLogs = parseRecentLogEntries(logEntry?.body ?? "").slice(0, 8);
const latestArticles = sortLatestArticles(
  articleEntries.map((entry) => ({
    title: fileTitle(entry),
    created: entry.data?.created,
    published: entry.data?.published,
    mtime: entry.filePath
      ? (() => {
          try {
            return statSync(join(process.cwd(), entry.filePath)).mtimeMs;
          } catch {
            return 0;
          }
        })()
      : 0,
  })),
).slice(0, 8);
const homeDescription =
  "Inspired by karpathy's llm-wiki idea, this site turns a markdown repository into a personal encyclopedia for AI, interfaces, and systems.";
---

<BaseLayout title="LLM Wiki" description={homeDescription}>
  <Header />
  <main class="home-shell">
    <article class="home-main content-prose" data-pagefind-body>
      <header class="article-header home-header">
        <h1 class="article-header__title">LLM Wiki</h1>
        <p>
          Inspired by
          <a href="https://gist.github.com/karpathy/442a6bf555914893e9891c11519de94f">karpathy's llm-wiki idea</a>, this
          site turns a markdown repository into a personal encyclopedia.
        </p>
        <p>
          Source lives in
          <a href="https://github.com/zoubingwu/llm-wiki">github.com/zoubingwu/llm-wiki</a>, with content maintained in <code
            >wiki/</code
          > and <code>articles/</code> through Obsidian-style wikilinks.
        </p>
      </header>
      <section class="home-section">
        <h2>Featured Concepts</h2>
        {
          featured.length === 0 ? (
            <p class="empty-note">No featured concepts yet.</p>
          ) : (
            <ul class="home-list">
              {featured.map((item) => (
                <li>
                  <a href={item.url}>{item.title}</a>
                </li>
              ))}
            </ul>
          )
        }
      </section>
      <section class="home-section">
        <h2>Latest Sources</h2>
        {
          latestArticles.length === 0 ? (
            <p class="empty-note">No source files yet.</p>
          ) : (
            <ul class="home-list">
              {latestArticles.map((item) => (
                <li>
                  <a href={pageUrl("articles", item.title)}>{item.title}</a>
                </li>
              ))}
            </ul>
          )
        }
      </section>
      <section class="home-section">
        <h2>Recent Activity</h2>
        {recentLogs.length === 0 && <p class="empty-note">No activity yet.</p>}
        <ul class="home-list">
          {recentLogs.map((entry) => <li>{entry.title}</li>)}
          <li><a href={pageUrl("wiki", "log")}>Full log</a></li>
        </ul>
      </section>
    </article>
  </main>
</BaseLayout>
