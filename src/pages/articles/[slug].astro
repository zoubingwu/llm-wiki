---
import { getCollection, render } from "astro:content";
import { basename } from "node:path";
import ArticleMetadata from "../../components/ArticleMetadata.astro";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { buildRegistry, resolvePage } from "../../lib/wiki/registry";
import { buildLinkGraph, graphKey } from "../../lib/wiki/backlinks";
import { excerptFromMarkdown, normalizeWikilinkLabel } from "../../lib/seo";

export async function getStaticPaths() {
  const articleEntries = await getCollection("articles");

  return articleEntries.map((entry) => ({
    params: { slug: entry.filePath ? basename(entry.filePath, ".md") : entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const title = entry.filePath ? basename(entry.filePath, ".md") : entry.id;
const { Content, headings } = await render(entry);
const wikiEntries = await getCollection("wiki");
const articleEntries = await getCollection("articles");
const registry = buildRegistry(process.cwd());
const graph = buildLinkGraph(
  [
    ...wikiEntries.map((item) => ({
      title: item.filePath ? basename(item.filePath, ".md") : item.id,
      collection: "wiki" as const,
      type: item.data.type,
      body: item.body ?? ""
    })),
    ...articleEntries.map((item) => ({
      title: item.filePath ? basename(item.filePath, ".md") : item.id,
      collection: "articles" as const,
      body: item.body ?? ""
    }))
  ],
  registry
);

const node = graph.get(graphKey({ collection: "articles", title }));

function formatDate(value: Date | string | null | undefined): string | null {
  if (!value) return null;
  if (value instanceof Date) return value.toISOString().slice(0, 10);
  return String(value);
}

function parseAuthor(value: string): { label: string; url?: string } {
  const match = value.match(/^\[\[([^[\]|]+)(?:\|([^[\]]+))?\]\]$/);
  if (!match) {
    return { label: value };
  }

  const target = match[1].trim();
  const label = (match[2] ?? match[1]).trim();
  const page = resolvePage(registry, target);
  return page?.collection === "wiki" ? { label, url: page.url } : { label };
}

const authors = Array.isArray(entry.data.author)
  ? entry.data.author.map(parseAuthor)
  : entry.data.author
    ? [parseAuthor(entry.data.author)]
    : [];
const authorNames = Array.isArray(entry.data.author)
  ? entry.data.author.map(normalizeWikilinkLabel)
  : entry.data.author
    ? [normalizeWikilinkLabel(entry.data.author)]
    : [];
const description =
  typeof entry.data.description === "string" && entry.data.description.trim().length > 0
    ? entry.data.description
    : excerptFromMarkdown(entry.body ?? "");
const publishedTime = formatDate(entry.data.published);
---

<ContentLayout
  title={title}
  description={description}
  canonical={entry.data.source ?? undefined}
  robots="noindex,follow"
  publishedTime={publishedTime ?? undefined}
  authors={authorNames}
  seeAlsoItems={node?.related ?? []}
  headings={headings}
  related={node?.related ?? []}
  backlinks={node?.backlinks ?? []}
  sources={node?.sources ?? []}
  kind="article"
>
  <ArticleMetadata
    slot="article-meta"
    authors={authors}
    published={formatDate(entry.data.published)}
    archived={formatDate(entry.data.created)}
    source={entry.data.source ?? null}
  />
  <article class="content-prose">
    <h1>{title}</h1>
    <Content />
  </article>
</ContentLayout>
