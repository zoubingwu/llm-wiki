---
import { getCollection, render } from "astro:content";
import { basename } from "node:path";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { buildRegistry } from "../../lib/wiki/registry";
import { buildLinkGraph, graphKey } from "../../lib/wiki/backlinks";
import { excerptFromMarkdown } from "../../lib/seo";

export async function getStaticPaths() {
  const wikiEntries = await getCollection("wiki");

  return wikiEntries.map((entry) => ({
    params: { slug: entry.filePath ? basename(entry.filePath, ".md") : entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const title = entry.filePath ? basename(entry.filePath, ".md") : entry.id;
const { Content, headings } = await render(entry);
const wikiEntries = await getCollection("wiki");
const articleEntries = await getCollection("articles");
const registry = buildRegistry(process.cwd());
const graph = buildLinkGraph(
  [
    ...wikiEntries.map((item) => ({
      title: item.filePath ? basename(item.filePath, ".md") : item.id,
      collection: "wiki" as const,
      type: item.data.type,
      body: item.body ?? ""
    })),
    ...articleEntries.map((item) => ({
      title: item.filePath ? basename(item.filePath, ".md") : item.id,
      collection: "articles" as const,
      body: item.body ?? ""
    }))
  ],
  registry
);

const node = graph.get(graphKey({ collection: "wiki", title }));
const description = excerptFromMarkdown(entry.body ?? "");
---

<ContentLayout
  title={title}
  description={description}
  seeAlsoItems={node?.related ?? []}
  headings={headings}
  related={node?.related ?? []}
  backlinks={node?.backlinks ?? []}
  sources={node?.sources ?? []}
>
  <article class="content-prose">
    <Content />
  </article>
</ContentLayout>
