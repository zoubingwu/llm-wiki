---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  ogType?: "website" | "article";
  robots?: string;
  publishedTime?: string;
  authors?: string[];
}

const {
  title,
  description,
  canonical,
  image = "/og-default.png",
  ogType = "website",
  robots = "index,follow",
  publishedTime,
  authors = []
} = Astro.props;
const siteName = "LLM Wiki";
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const currentUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const canonicalUrl = canonical ?? currentUrl;
const imageUrl = Astro.site ? new URL(image, Astro.site).toString() : image;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="robots" content={robots} />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={currentUrl} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={imageUrl} />
    {ogType === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" &&
      authors.map((author) => <meta property="article:author" content={author} />)}
  </head>
  <body>
    <slot />
  </body>
</html>
