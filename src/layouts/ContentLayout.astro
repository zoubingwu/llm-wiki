---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import BrowseSidebar from "../components/BrowseSidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import FooterPanels from "../components/FooterPanels.astro";

const { title, browseItems, headings, related, backlinks, sources, kind = "wiki" } = Astro.props;
const byline =
  kind === "article" ? "From the LLM Wiki source archive" : "From LLM Wiki, the personal encyclopedia";
---

<BaseLayout title={title}>
  <Header />
  <div class="page-shell page-shell--article">
    <TableOfContents headings={headings} />
    <main class="page-main" data-pagefind-body>
      <header class="article-header">
        <h1 class="article-header__title">{title}</h1>
        <p class="article-header__byline">{byline}</p>
      </header>
      <slot />
      <FooterPanels related={related} backlinks={backlinks} sources={sources} />
    </main>
    <BrowseSidebar items={browseItems} />
  </div>
</BaseLayout>
