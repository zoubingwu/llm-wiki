---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import BrowseSidebar from "../components/BrowseSidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import FooterPanels from "../components/FooterPanels.astro";

const {
  title,
  description,
  canonical,
  robots,
  image,
  publishedTime,
  authors,
  seeAlsoItems,
  headings,
  related,
  backlinks,
  sources
} = Astro.props;
const sidebarItems = seeAlsoItems ?? related;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  robots={robots}
  image={image}
  ogType="article"
  publishedTime={publishedTime}
  authors={authors}
>
  <Header />
  <div class={`page-shell page-shell--article${sidebarItems.length === 0 ? " page-shell--no-sidebar" : ""}`}>
    <TableOfContents headings={headings} />
    <main class="page-main" data-pagefind-body>
      <header class="article-header">
        <h1 class="article-header__title">{title}</h1>
      </header>
      <slot name="article-meta" />
      <slot />
      <FooterPanels backlinks={backlinks} sources={sources} />
    </main>
    <BrowseSidebar items={sidebarItems} />
  </div>
</BaseLayout>
