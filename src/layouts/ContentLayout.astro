---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import BrowseSidebar from "../components/BrowseSidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import FooterPanels from "../components/FooterPanels.astro";

const { title, seeAlsoItems, headings, related, backlinks, sources, kind = "wiki" } = Astro.props;
const sidebarItems = seeAlsoItems ?? related;
const byline =
  kind === "article" ? "From the LLM Wiki source archive" : "From LLM Wiki, the personal encyclopedia";
---

<BaseLayout title={title}>
  <Header />
  <div class={`page-shell page-shell--article${sidebarItems.length === 0 ? " page-shell--no-sidebar" : ""}`}>
    <TableOfContents headings={headings} />
    <main class="page-main" data-pagefind-body>
      <header class="article-header">
        <h1 class="article-header__title">{title}</h1>
        <p class="article-header__byline">{byline}</p>
      </header>
      <slot name="article-meta" />
      <slot />
      <FooterPanels backlinks={backlinks} sources={sources} />
    </main>
    <BrowseSidebar items={sidebarItems} />
  </div>
</BaseLayout>
