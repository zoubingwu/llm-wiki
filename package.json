{
  "name": "llm-wiki-web",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "node scripts/sync-wiki-assets.mjs && astro dev",
    "build": "node scripts/sync-wiki-assets.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "deploy": "pnpm run build && wrangler deploy",
    "check": "astro check",
    "wiki:check-titles": "node scripts/check-wiki-title-collisions.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "astro": "6.1.8",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@types/node": "25.6.0",
    "pagefind": "1.5.2",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "typescript": "5.9.3",
    "unified": "11.0.5",
    "vitest": "4.1.5",
    "wrangler": "4.84.1"
  }
}
